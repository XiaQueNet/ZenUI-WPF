root = true

[*]
end_of_line = crlf

[*.{sh,bash,zsh,fish,ps1,psm1,psd1,cmd,bat,py,rb,pl,js,mjs,cjs,ts,tsx,jsx}]
end_of_line = lf

[*.{cs,xaml,csproj,props,targets,slnx}]
charset = utf-8
insert_final_newline = true
indent_style = space
indent_size = 4

[*.cs]
end_of_line = crlf

dotnet_sort_system_directives_first = true
csharp_new_line_before_open_brace = all

[*.xaml]
end_of_line = crlf

[*.{csproj,props,targets,slnx}]
end_of_line = crlf
indent_size = 2

[*.md]
end_of_line = crlf
