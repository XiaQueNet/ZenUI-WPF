<UserControl
    x:Class="ZenUI.Wpf.Demo.Views.PasswordBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:demo="clr-namespace:ZenUI.Wpf.Demo.Controls"
    xmlns:zen="http://zenui.mnorg.com/zenui-wpf">
    <ScrollViewer Padding="40" HorizontalContentAlignment="Stretch" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <demo:PageHeader Description="用于输入需要隐藏显示的密码或其他敏感文本。" Title="PasswordBox 密码框" />
            <Border Style="{StaticResource DemoCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="基本用法" />
                    <zen:ZenPasswordBox Width="320" HorizontalAlignment="Left" Watermark="请输入密码" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DemoCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="圆角" />
                    <StackPanel Orientation="Horizontal">
                        <zen:ZenPasswordBox Width="220" Margin="0,0,16,0" CornerRadius="0" Watermark="直角密码框" />
                        <zen:ZenPasswordBox Width="220" Margin="0,0,16,0" CornerRadius="6" Watermark="默认圆角" />
                        <zen:ZenPasswordBox Width="220" CornerRadius="18" Watermark="大圆角密码框" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DemoCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="控件状态" />
                    <StackPanel Orientation="Horizontal">
                        <zen:ZenPasswordBox Width="220" Margin="0,0,16,0" Watermark="请输入密码" />
                        <zen:ZenPasswordBox Width="220" Margin="0,0,16,0" Watermark="已有内容状态请实际输入" />
                        <zen:ZenPasswordBox Width="220" IsEnabled="False" Watermark="不可输入" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
