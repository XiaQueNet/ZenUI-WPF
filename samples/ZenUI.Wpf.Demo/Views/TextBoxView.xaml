<UserControl
    x:Class="ZenUI.Wpf.Demo.Views.TextBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:demo="clr-namespace:ZenUI.Wpf.Demo.Controls"
    xmlns:zen="http://zenui.mnorg.com/zenui-wpf">
    <ScrollViewer Padding="40" HorizontalContentAlignment="Stretch" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <demo:PageHeader Description="用于输入文本，支持水印、自定义圆角和常用交互状态。" Title="TextBox 输入框" />
            <Border Style="{StaticResource DemoCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="基本用法" />
                    <zen:ZenTextBox Width="320" HorizontalAlignment="Left" Watermark="请输入内容" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DemoCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="圆角" />
                    <StackPanel Orientation="Horizontal">
                        <zen:ZenTextBox Width="220" Margin="0,0,16,0" CornerRadius="0" Watermark="直角输入框" />
                        <zen:ZenTextBox Width="220" Margin="0,0,16,0" CornerRadius="6" Watermark="默认圆角" />
                        <zen:ZenTextBox Width="220" CornerRadius="18" Watermark="大圆角输入框" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DemoCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="控件状态" />
                    <StackPanel Orientation="Horizontal">
                        <zen:ZenTextBox Width="220" Margin="0,0,16,0" Text="ZenUI.Wpf" />
                        <zen:ZenTextBox Width="220" Margin="0,0,16,0" IsReadOnly="True" Text="只读内容" />
                        <zen:ZenTextBox Width="220" IsEnabled="False" Watermark="不可输入" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
