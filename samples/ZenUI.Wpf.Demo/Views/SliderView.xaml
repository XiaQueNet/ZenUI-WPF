<UserControl
    x:Class="ZenUI.Wpf.Demo.Views.SliderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:demo="clr-namespace:ZenUI.Wpf.Demo.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:zen="http://zenui.mnorg.com/zenui-wpf"
    prism:ViewModelLocator.AutoWireViewModel="True">
    <ScrollViewer Padding="40" HorizontalContentAlignment="Stretch" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <demo:PageHeader Description="用于在连续或分段区间内选择一个数值。" Title="Slider 滑块" />
            <Border Style="{StaticResource DemoCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="实时数值" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <zen:ZenSlider Maximum="100" TickFrequency="10" Value="{Binding Value, Mode=TwoWay}" />
                        <TextBlock Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource ZenTextSecondaryBrush}" Text="{Binding Value, StringFormat={}{0:F0}%}" />
                    </Grid>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DemoCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="不同范围" />
                    <Grid Margin="0,0,0,8">
                        <TextBlock Foreground="{DynamicResource ZenTextSecondaryBrush}" Text="亮度 · 0–100" />
                        <TextBlock HorizontalAlignment="Right" Foreground="{DynamicResource ZenTextSecondaryBrush}" Text="{Binding Value, ElementName=BrightnessSlider, StringFormat={}{0:F0}%}" />
                    </Grid>
                    <zen:ZenSlider x:Name="BrightnessSlider" Maximum="100" Value="65" />
                    <Grid Margin="0,20,0,8">
                        <TextBlock Foreground="{DynamicResource ZenTextSecondaryBrush}" Text="字号 · 12–24，步进 2" />
                        <TextBlock HorizontalAlignment="Right" Foreground="{DynamicResource ZenTextSecondaryBrush}" Text="{Binding Value, ElementName=FontSizeSlider, StringFormat={}{0:F0} px}" />
                    </Grid>
                    <zen:ZenSlider x:Name="FontSizeSlider" IsSnapToTickEnabled="True" Maximum="24" Minimum="12" TickFrequency="2" Value="16" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DemoCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="禁用状态" />
                    <TextBlock Margin="0,0,0,8" Foreground="{DynamicResource ZenTextSecondaryBrush}" Text="当前值 · 35%" />
                    <zen:ZenSlider IsEnabled="False" Maximum="100" Value="35" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
