<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:zen="http://zenui.mnorg.com/zenui-wpf">

    <SolidColorBrush x:Key="DemoSidebarBrush" Color="#172033" />
    <SolidColorBrush x:Key="DemoSidebarItemBrush" Color="#AEB8CA" />
    <SolidColorBrush x:Key="DemoSidebarItemHoverBrush" Color="#202D45" />
    <SolidColorBrush x:Key="DemoSidebarItemSelectedBrush" Color="#223657" />
    <SolidColorBrush x:Key="DemoSidebarSecondaryTextBrush" Color="#8E9BB1" />
    <SolidColorBrush x:Key="DemoSidebarFooterTextBrush" Color="#8491A8" />
    <SolidColorBrush x:Key="DemoOnPrimarySecondaryBrush" Color="#DFE6FA" />
    <SolidColorBrush x:Key="DemoOnPrimaryMutedSurfaceBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="DemoSuccessForegroundBrush" Color="#064E2C" />
    <SolidColorBrush x:Key="DemoErrorForegroundBrush" Color="#681515" />

    <Style x:Key="PageTitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource ZenTextPrimaryBrush}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PageDescriptionStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Margin" Value="0,8,0,28" />
        <Setter Property="Foreground" Value="{DynamicResource ZenTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Margin" Value="0,0,0,18" />
        <Setter Property="Foreground" Value="{DynamicResource ZenTextPrimaryBrush}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="DemoFieldLabelStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Foreground" Value="{DynamicResource ZenTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="DemoSupportingTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource ZenTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="DemoCardStyle" TargetType="{x:Type Border}">
        <Setter Property="Margin" Value="0,0,0,18" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Background" Value="{DynamicResource ZenSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ZenDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="DemoButtonStyle" BasedOn="{StaticResource ZenButtonStyle}" TargetType="{x:Type zen:ZenButton}">
        <Setter Property="MinWidth" Value="92" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="Padding" Value="16,0" />
    </Style>
</ResourceDictionary>
