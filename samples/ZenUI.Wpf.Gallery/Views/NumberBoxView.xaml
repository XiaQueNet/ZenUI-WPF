<UserControl
    x:Class="ZenUI.Wpf.Gallery.Views.NumberBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:gallery="clr-namespace:ZenUI.Wpf.Gallery.Controls"
    xmlns:zen="http://zenui.mnorg.com/zenui-wpf">
    <ScrollViewer Padding="40" HorizontalContentAlignment="Stretch" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <gallery:PageHeader Description="支持范围约束、可配置步长和两种按钮布局。" Title="NumberBox 数字输入框" />

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="左右增减按钮" />
                    <TextBlock
                        Margin="0,0,0,10"
                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                        Text="适合数量、页码等需要醒目操作按钮的场景。" />
                    <zen:ZenNumberBox
                        Width="180"
                        HorizontalAlignment="Left"
                        Maximum="20"
                        Minimum="0"
                        Step="1"
                        Value="5" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="右侧上下按钮" />
                    <TextBlock
                        Margin="0,0,0,10"
                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                        Text="紧凑布局，步长设为 0.5，值始终限制在 0–10。" />
                    <zen:ZenNumberBox
                        Width="180"
                        HorizontalAlignment="Left"
                        ButtonMode="Vertical"
                        Maximum="10"
                        Minimum="0"
                        Step="0.5"
                        Value="2.5" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="状态" />
                    <StackPanel Orientation="Horizontal">
                        <zen:ZenNumberBox
                            Width="180"
                            IsReadOnly="True"
                            Step="10"
                            Value="100" />
                        <zen:ZenNumberBox
                            Width="180"
                            Margin="16,0,0,0"
                            ButtonMode="Vertical"
                            IsEnabled="False"
                            Value="12" />
                    </StackPanel>
                    <TextBlock
                        Margin="0,10,0,0"
                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                        Text="左：只读文本（按钮可用）　右：禁用" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
