<UserControl
    x:Class="ZenUI.Wpf.Gallery.Views.SwitchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:gallery="clr-namespace:ZenUI.Wpf.Gallery.Controls"
    xmlns:zen="http://zenui.mnorg.com/zenui-wpf">
    <ScrollViewer Padding="40" HorizontalContentAlignment="Stretch" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <gallery:PageHeader Description="用于在打开和关闭状态之间即时切换。" Title="Switch 开关" />
            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="基本状态" />
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,40,0">
                            <zen:ZenSwitch IsChecked="True" />
                            <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource ZenTextSecondaryBrush}" Text="开启" />
                        </StackPanel>
                        <StackPanel>
                            <zen:ZenSwitch />
                            <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource ZenTextSecondaryBrush}" Text="关闭" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="禁用状态" />
                    <StackPanel Orientation="Horizontal">
                        <zen:ZenSwitch Margin="0,0,24,0" IsChecked="True" IsEnabled="False" />
                        <zen:ZenSwitch IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="不同宽度" />
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,40,0">
                            <zen:ZenSwitch Width="48" IsChecked="True" />
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource GallerySupportingTextStyle}" Text="紧凑" />
                        </StackPanel>
                        <StackPanel Margin="0,0,40,0">
                            <zen:ZenSwitch IsChecked="True" />
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource GallerySupportingTextStyle}" Text="默认" />
                        </StackPanel>
                        <StackPanel>
                            <zen:ZenSwitch Width="80" IsChecked="True" />
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource GallerySupportingTextStyle}" Text="宽型" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="设置列表" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="桌面通知" />
                            <TextBlock Style="{StaticResource GallerySupportingTextStyle}" Text="有新消息时显示系统通知。" />
                        </StackPanel>
                        <zen:ZenSwitch Grid.Column="1" Margin="24,0,0,0" IsChecked="True" />
                    </Grid>
                    <Border Margin="0,18,0,18" BorderBrush="{DynamicResource ZenDividerBrush}" BorderThickness="0,1,0,0" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="自动下载更新" />
                            <TextBlock Style="{StaticResource GallerySupportingTextStyle}" Text="连接到非计费网络时下载最新版本。" />
                        </StackPanel>
                        <zen:ZenSwitch Grid.Column="1" Margin="24,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
