<UserControl
    x:Class="ZenUI.Wpf.Gallery.Views.TextBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:gallery="clr-namespace:ZenUI.Wpf.Gallery.Controls"
    xmlns:zen="http://zenui.mnorg.com/zenui-wpf">
    <ScrollViewer
        Padding="40"
        HorizontalContentAlignment="Stretch"
        VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <gallery:PageHeader Title="TextBox 输入框" Description="用于输入单行或多行文本，支持水印、前后置内容、自定义圆角和常用交互状态。" />
            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="基本用法" />
                    <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="名称" />
                    <zen:ZenTextBox
                        Width="320"
                        HorizontalAlignment="Left"
                        AutomationProperties.Name="名称"
                        Watermark="请输入名称" />
                    <TextBlock
                        Width="320"
                        HorizontalAlignment="Left"
                        Style="{StaticResource GallerySupportingTextStyle}"
                        Text="Watermark 仅在内容为空且输入框未获得焦点时显示。" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="前后置内容" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="搜索框 · 前置图标与可交互后置按钮" />
                            <zen:ZenTextBox
                                x:Name="SearchInput"
                                Height="44"
                                AutomationProperties.Name="搜索"
                                Watermark="搜索组件、属性或示例">
                                <zen:ZenTextBox.LeadingContent>
                                    <Path
                                        Width="18"
                                        Height="18"
                                        Data="M10,3 A7,7 0 1 0 10,17 A7,7 0 1 0 10,3 M15,15 L21,21"
                                        Stretch="Uniform"
                                        Stroke="{DynamicResource ZenTextSecondaryBrush}"
                                        StrokeEndLineCap="Round"
                                        StrokeThickness="1.7" />
                                </zen:ZenTextBox.LeadingContent>
                                <zen:ZenTextBox.TrailingContent>
                                    <zen:ZenButton
                                        Width="26"
                                        Height="26"
                                        Padding="0"
                                        Appearance="Text"
                                        AutomationProperties.Name="清除搜索内容"
                                        Click="ClearSearchButton_Click"
                                        Content="×"
                                        FontSize="18"
                                        ToolTip="清除" />
                                </zen:ZenTextBox.TrailingContent>
                            </zen:ZenTextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="地址 · 文本前缀与后缀" />
                            <zen:ZenTextBox
                                Height="44"
                                AutomationProperties.Name="站点地址"
                                Watermark="your-site">
                                <zen:ZenTextBox.LeadingContent>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                        Text="https://" />
                                </zen:ZenTextBox.LeadingContent>
                                <zen:ZenTextBox.TrailingContent>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                        Text=".com" />
                                </zen:ZenTextBox.TrailingContent>
                            </zen:ZenTextBox>
                        </StackPanel>
                    </Grid>
                    <TextBlock
                        Margin="0,12,0,0"
                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                        Text="LeadingContent 与 TrailingContent 接受任意对象，也可以配合对应的 ContentTemplate 使用。"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="尺寸" />
                    <UniformGrid Columns="3">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="紧凑 · Height=32" />
                            <zen:ZenTextBox Height="32" Watermark="紧凑输入框" />
                        </StackPanel>
                        <StackPanel Margin="5,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="默认 · MinHeight=36" />
                            <zen:ZenTextBox Watermark="默认输入框" />
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="宽松 · Height=48" />
                            <zen:ZenTextBox Height="48" Watermark="宽松输入框" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="圆角" />
                    <UniformGrid Columns="3">
                        <zen:ZenTextBox
                            Margin="0,0,10,0"
                            CornerRadius="0"
                            Watermark="直角 · 0" />
                        <zen:ZenTextBox
                            Margin="5,0"
                            CornerRadius="6"
                            Watermark="默认 · 6" />
                        <zen:ZenTextBox
                            Margin="10,0,0,0"
                            CornerRadius="18"
                            Watermark="胶囊 · 18" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="多行输入" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="自动换行与垂直滚动" />
                            <zen:ZenTextBox
                                Height="104"
                                VerticalContentAlignment="Top"
                                AcceptsReturn="True"
                                AutomationProperties.Name="备注"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                Watermark="请输入备注" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="限制输入长度 · MaxLength=120" />
                            <zen:ZenTextBox
                                Height="104"
                                VerticalContentAlignment="Top"
                                AcceptsReturn="True"
                                AutomationProperties.Name="摘要"
                                MaxLength="120"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                Watermark="最多输入 120 个字符" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="控件状态" />
                    <UniformGrid Columns="3">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="正常" />
                            <zen:ZenTextBox Text="ZenUI.Wpf" />
                        </StackPanel>
                        <StackPanel Margin="5,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="只读" />
                            <zen:ZenTextBox IsReadOnly="True" Text="只读内容" />
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="禁用" />
                            <zen:ZenTextBox IsEnabled="False" Watermark="不可输入" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="推荐用法" />
                    <Border
                        Padding="16"
                        Background="{DynamicResource ZenSurfaceMutedBrush}"
                        CornerRadius="8">
                        <TextBlock
                            FontFamily="Consolas"
                            Foreground="{DynamicResource ZenTextPrimaryBrush}"
                            Text="&lt;zen:ZenTextBox&#x0a;    Watermark=&quot;请输入关键字&quot;&gt;&#x0a;    &lt;zen:ZenTextBox.LeadingContent&gt;&#x0a;        &lt;Path Data=&quot;{StaticResource SearchIcon}&quot; /&gt;&#x0a;    &lt;/zen:ZenTextBox.LeadingContent&gt;&#x0a;&lt;/zen:ZenTextBox&gt;"
                            TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
