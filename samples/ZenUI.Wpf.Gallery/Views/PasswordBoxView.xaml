<UserControl
    x:Class="ZenUI.Wpf.Gallery.Views.PasswordBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:gallery="clr-namespace:ZenUI.Wpf.Gallery.Controls"
    xmlns:zen="http://zenui.mnorg.com/zenui-wpf">
    <ScrollViewer Padding="40" HorizontalContentAlignment="Stretch" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <gallery:PageHeader
                Description="用于安全输入密码等敏感文本，支持水印、自定义圆角以及可选的密码显示与隐藏功能。"
                Title="PasswordBox 密码框" />

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="登录场景" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="带前置内容的登录输入框" />
                            <zen:ZenTextBox
                                Width="320"
                                Height="48"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="登录账号"
                                Watermark="请输入账号">
                                <zen:ZenTextBox.LeadingContent>
                                    <Path
                                        Width="22"
                                        Height="22"
                                        Margin="10,0,0,0"
                                        Data="M12,12 A4,4 0 1 0 12,4 A4,4 0 1 0 12,12 M5,21 C5,16 8,13 12,13 C16,13 19,16 19,21"
                                        Stretch="Uniform"
                                        Stroke="{DynamicResource ZenTextSecondaryBrush}"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        StrokeThickness="1.6" />
                                </zen:ZenTextBox.LeadingContent>
                            </zen:ZenTextBox>
                            <zen:ZenPasswordBox
                                Width="320"
                                Height="48"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="账户密码"
                                IsPasswordRevealEnabled="True"
                                Watermark="请输入账户密码">
                                <zen:ZenPasswordBox.LeadingContent>
                                    <Path
                                        Width="22"
                                        Height="22"
                                        Margin="10,0,0,0"
                                        Data="M7,10 V7 A5,5 0 0 1 17,7 V10 M6,10 H18 V21 H6 Z M12,14 V17"
                                        Stretch="Uniform"
                                        Stroke="{DynamicResource ZenTextSecondaryBrush}"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        StrokeThickness="1.6" />
                                </zen:ZenPasswordBox.LeadingContent>
                            </zen:ZenPasswordBox>
                            <TextBlock
                                Margin="0,10,0,0"
                                MaxWidth="320"
                                HorizontalAlignment="Left"
                                Style="{StaticResource GallerySupportingTextStyle}"
                                Text="前后内容接受任意对象；眼睛按钮由密码框管理，点击可切换明文。" />
                            <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                                <zen:ZenButton Content="登录" Style="{StaticResource GalleryButtonStyle}" />
                                <zen:ZenButton Content="忘记密码" Style="{StaticResource GalleryButtonStyle}" Variant="Success" />
                            </StackPanel>
                        </StackPanel>

                        <Border
                            Grid.Column="2"
                            Padding="20"
                            VerticalAlignment="Stretch"
                            Background="{DynamicResource ZenSurfaceMutedBrush}"
                            CornerRadius="8">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="15" FontWeight="SemiBold" Text="内置安全行为" />
                                <TextBlock
                                    Margin="0,12,0,0"
                                    Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                    LineHeight="23"
                                    Text="✓ TextBox 与 PasswordBox API 一致&#x0a;✓ 支持前置和后置内容模板&#x0a;✓ 密码显隐按钮保持独立&#x0a;✓ 空插槽不会占用布局空间"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="交互配置" />
                    <TextBlock
                        Margin="0,0,0,16"
                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                        Text="使用右侧开关实时体验显隐功能；即使密码为空，启用后眼睛按钮也会保持显示。"
                        TextWrapping="Wrap" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="280" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="可配置密码框" />
                            <zen:ZenPasswordBox
                                x:Name="InteractivePasswordBox"
                                Width="320"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="可配置密码框"
                                IsEnabled="{Binding IsChecked, ElementName=ControlEnabledSwitch}"
                                IsPasswordRevealEnabled="{Binding IsChecked, ElementName=RevealEnabledSwitch}"
                                Watermark="输入内容后点击眼睛" />
                            <TextBlock
                                Margin="0,10,0,0"
                                Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                Text="{Binding IsPasswordRevealed, ElementName=InteractivePasswordBox, StringFormat=当前明文状态：{0}}" />
                        </StackPanel>

                        <Border
                            Grid.Column="2"
                            Padding="18"
                            Background="{DynamicResource ZenSurfaceMutedBrush}"
                            CornerRadius="8">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock VerticalAlignment="Center" Text="启用眼睛按钮" />
                                    <zen:ZenSwitch
                                        x:Name="RevealEnabledSwitch"
                                        HorizontalAlignment="Right"
                                        AutomationProperties.Name="启用眼睛按钮"
                                        IsChecked="True" />
                                </Grid>
                                <Grid>
                                    <TextBlock VerticalAlignment="Center" Text="启用密码框" />
                                    <zen:ZenSwitch
                                        x:Name="ControlEnabledSwitch"
                                        HorizontalAlignment="Right"
                                        AutomationProperties.Name="启用密码框"
                                        IsChecked="True" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="显隐功能对比" />
                    <UniformGrid Columns="2">
                        <Border Margin="0,0,8,0" Padding="18" BorderBrush="{DynamicResource ZenDividerBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="默认安全模式" />
                                <TextBlock
                                    Margin="0,6,0,14"
                                    Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                    Text="不显示眼睛按钮，保持传统密码输入体验。" />
                                <zen:ZenPasswordBox Watermark="IsPasswordRevealEnabled=False" />
                            </StackPanel>
                        </Border>
                        <Border Margin="8,0,0,0" Padding="18" BorderBrush="{DynamicResource ZenDividerBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="允许显示密码" />
                                <TextBlock
                                    Margin="0,6,0,14"
                                    Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                    Text="眼睛按钮始终显示，空密码状态下也不会消失。" />
                                <zen:ZenPasswordBox IsPasswordRevealEnabled="True" Watermark="IsPasswordRevealEnabled=True" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="圆角与尺寸" />
                    <UniformGrid Columns="3">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="直角 · CornerRadius=0" />
                            <zen:ZenPasswordBox CornerRadius="0" IsPasswordRevealEnabled="True" Watermark="直角密码框" />
                        </StackPanel>
                        <StackPanel Margin="5,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="默认 · CornerRadius=6" />
                            <zen:ZenPasswordBox CornerRadius="6" IsPasswordRevealEnabled="True" Watermark="默认圆角" />
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="胶囊 · CornerRadius=18" />
                            <zen:ZenPasswordBox CornerRadius="18" IsPasswordRevealEnabled="True" Watermark="大圆角密码框" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="控件状态" />
                    <UniformGrid Columns="3">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="正常状态" />
                            <zen:ZenPasswordBox IsPasswordRevealEnabled="True" Watermark="可以输入密码" />
                        </StackPanel>
                        <StackPanel Margin="5,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="禁用显隐功能" />
                            <zen:ZenPasswordBox Watermark="没有眼睛按钮" />
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="禁用状态" />
                            <zen:ZenPasswordBox IsEnabled="False" IsPasswordRevealEnabled="True" Watermark="不可输入" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="推荐用法" />
                    <Border Padding="16" Background="{DynamicResource ZenSurfaceMutedBrush}" CornerRadius="8">
                        <TextBlock
                            FontFamily="Consolas"
                            Foreground="{DynamicResource ZenTextPrimaryBrush}"
                            Text="&lt;zen:ZenPasswordBox&#x0a;    Width=&quot;320&quot;&#x0a;    Watermark=&quot;请输入密码&quot;&#x0a;    IsPasswordRevealEnabled=&quot;True&quot; /&gt;"
                            TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
