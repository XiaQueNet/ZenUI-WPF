<UserControl
    x:Class="ZenUI.Wpf.Gallery.Views.AlertView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:gallery="clr-namespace:ZenUI.Wpf.Gallery.Controls"
    xmlns:zen="http://zenui.mnorg.com/zenui-wpf">
    <ScrollViewer Padding="40" HorizontalContentAlignment="Stretch" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <gallery:PageHeader Description="用于页面内的操作反馈、系统状态和重要说明。" Title="Alert 状态提示" />
            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="语义类型" />
                    <zen:ZenAlert Margin="0,0,0,12" Content="这是一条信息提示，请留意相关说明。" Variant="Info" />
                    <zen:ZenAlert Margin="0,0,0,12" Content="保存成功，修改内容已生效。" Variant="Success" />
                    <zen:ZenAlert Margin="0,0,0,12" Content="当前配置存在潜在风险，请检查后继续。" Variant="Warning" />
                    <zen:ZenAlert Content="提交失败，请检查网络连接后重试。" Variant="Error" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="富内容" />
                    <zen:ZenAlert Variant="Success">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="发布已完成" />
                            <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource ZenTextSecondaryBrush}" Text="版本 0.1.0-preview.1 已发布预览。" />
                        </StackPanel>
                    </zen:ZenAlert>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
