<UserControl
    x:Class="ZenUI.Wpf.Gallery.Views.ButtonView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:gallery="clr-namespace:ZenUI.Wpf.Gallery.Controls"
    xmlns:zen="http://zenui.mnorg.com/zenui-wpf">
    <ScrollViewer Padding="40" HorizontalContentAlignment="Stretch" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <gallery:PageHeader Description="用于触发操作，可组合填充、描边和文本外观，以及主要、成功和警告语义。" Title="Button 按钮" />
            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="外观与语义" />
                    <TextBlock
                        Margin="0,0,0,16"
                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                        Text="Appearance 控制表现形式，Variant 控制操作语义；两者可以自由组合。"
                        TextWrapping="Wrap" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource ZenTextSecondaryBrush}"
                            Text="Filled" />
                        <WrapPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                            <zen:ZenButton Content="主要按钮" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Content="成功按钮" Style="{StaticResource GalleryButtonStyle}" Variant="Success" />
                            <zen:ZenButton Content="警告按钮" Style="{StaticResource GalleryButtonStyle}" Variant="Warning" />
                        </WrapPanel>
                        <TextBlock
                            Grid.Row="1"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource ZenTextSecondaryBrush}"
                            Text="Outlined" />
                        <WrapPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                            <zen:ZenButton Appearance="Outlined" Content="主要按钮" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Appearance="Outlined" Content="成功按钮" Style="{StaticResource GalleryButtonStyle}" Variant="Success" />
                            <zen:ZenButton Appearance="Outlined" Content="警告按钮" Style="{StaticResource GalleryButtonStyle}" Variant="Warning" />
                        </WrapPanel>
                        <TextBlock
                            Grid.Row="2"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource ZenTextSecondaryBrush}"
                            Text="Text" />
                        <WrapPanel Grid.Row="2" Grid.Column="1">
                            <zen:ZenButton Appearance="Text" Content="主要按钮" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Appearance="Text" Content="成功按钮" Style="{StaticResource GalleryButtonStyle}" Variant="Success" />
                            <zen:ZenButton Appearance="Text" Content="警告按钮" Style="{StaticResource GalleryButtonStyle}" Variant="Warning" />
                        </WrapPanel>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="按钮状态" />
                    <TextBlock
                        Margin="0,0,0,16"
                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                        Text="将鼠标移到可用按钮上并按下，可以查看 Hover 和 Pressed 状态。"
                        TextWrapping="Wrap" />
                    <WrapPanel Margin="0,0,0,12">
                        <zen:ZenButton Content="填充状态" Style="{StaticResource GalleryButtonStyle}" />
                        <zen:ZenButton Content="填充禁用" IsEnabled="False" Style="{StaticResource GalleryButtonStyle}" />
                    </WrapPanel>
                    <WrapPanel Margin="0,0,0,12">
                        <zen:ZenButton Appearance="Outlined" Content="描边状态" Style="{StaticResource GalleryButtonStyle}" />
                        <zen:ZenButton Appearance="Outlined" Content="描边禁用" IsEnabled="False" Style="{StaticResource GalleryButtonStyle}" />
                    </WrapPanel>
                    <WrapPanel>
                        <zen:ZenButton Appearance="Text" Content="文本状态" Style="{StaticResource GalleryButtonStyle}" />
                        <zen:ZenButton Appearance="Text" Content="文本禁用" IsEnabled="False" Style="{StaticResource GalleryButtonStyle}" />
                    </WrapPanel>
                    <Border
                        Margin="0,20,0,16"
                        BorderBrush="{DynamicResource ZenDividerBrush}"
                        BorderThickness="0,1,0,0" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                        Text="交互颜色属性可以覆盖主题默认值，下面的按钮分别定制了背景、文字和边框状态色。"
                        TextWrapping="Wrap" />
                    <zen:ZenButton
                        Width="132"
                        Height="36"
                        HorizontalAlignment="Left"
                        Appearance="Outlined"
                        Background="Transparent"
                        BorderBrush="#7C3AED"
                        Content="自定义交互颜色"
                        Foreground="#7C3AED"
                        HoverBackground="#F3E8FF"
                        HoverBorderBrush="#6D28D9"
                        HoverForeground="#6D28D9"
                        PressedBackground="#E9D5FF"
                        PressedBorderBrush="#5B21B6"
                        PressedForeground="#5B21B6" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource GalleryCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="圆角定制" />
                    <TextBlock
                        Margin="0,0,0,16"
                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                        Text="CornerRadius 支持统一圆角和四角独立设置；胶囊按钮的圆角等于按钮高度的一半。"
                        TextWrapping="Wrap" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource ZenTextSecondaryBrush}"
                            Text="Filled" />
                        <WrapPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                            <zen:ZenButton Content="直角 0" CornerRadius="0" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Content="小圆角 4" CornerRadius="4" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Content="默认 10" CornerRadius="10" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Content="大圆角 14" CornerRadius="14" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Content="胶囊 18" CornerRadius="18" Style="{StaticResource GalleryButtonStyle}" />
                        </WrapPanel>
                        <TextBlock
                            Grid.Row="1"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource ZenTextSecondaryBrush}"
                            Text="Outlined" />
                        <WrapPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                            <zen:ZenButton Appearance="Outlined" Content="直角 0" CornerRadius="0" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Appearance="Outlined" Content="小圆角 4" CornerRadius="4" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Appearance="Outlined" Content="默认 10" CornerRadius="10" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Appearance="Outlined" Content="大圆角 14" CornerRadius="14" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Appearance="Outlined" Content="胶囊 18" CornerRadius="18" Style="{StaticResource GalleryButtonStyle}" />
                        </WrapPanel>
                        <TextBlock
                            Grid.Row="2"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource ZenTextSecondaryBrush}"
                            Text="独立四角" />
                        <WrapPanel Grid.Row="2" Grid.Column="1">
                            <zen:ZenButton Appearance="Outlined" Content="左侧圆角" CornerRadius="18,0,0,18" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Appearance="Outlined" Content="右侧圆角" CornerRadius="0,18,18,0" Style="{StaticResource GalleryButtonStyle}" />
                            <zen:ZenButton Appearance="Outlined" Content="对角圆角" CornerRadius="18,0,18,0" Style="{StaticResource GalleryButtonStyle}" />
                        </WrapPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
