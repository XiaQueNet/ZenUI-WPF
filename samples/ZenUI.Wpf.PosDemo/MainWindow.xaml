<Window
    x:Class="ZenUI.Wpf.PosDemo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:navigation="clr-namespace:ZenUI.Wpf.PosDemo.Navigation"
    xmlns:prism="http://prismlibrary.com/"
    Title="ZenUI POS · 收银台"
    Width="1360"
    Height="860"
    MinWidth="1120"
    MinHeight="700"
    Background="{DynamicResource ZenSurfaceMutedBrush}"
    FontFamily="Microsoft YaHei UI"
    Foreground="{DynamicResource ZenTextPrimaryBrush}"
    ResizeMode="NoResize"
    WindowState="Maximized"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <ContentControl prism:RegionManager.RegionName="{x:Static navigation:RegionNames.MainRegion}" />
</Window>
