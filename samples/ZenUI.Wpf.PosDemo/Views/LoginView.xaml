<UserControl
    x:Class="ZenUI.Wpf.PosDemo.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:zen="http://zenui.mnorg.com/zenui-wpf"
    Background="{DynamicResource ZenSurfaceBrush}"
    FontFamily="Microsoft YaHei UI"
    Foreground="{DynamicResource ZenTextPrimaryBrush}"
    prism:Dialog.WindowStartupLocation="CenterScreen">
    <prism:Dialog.WindowStyle>
        <Style TargetType="{x:Type Window}">
            <Setter Property="Title" Value="ZenUI POS" />
            <Setter Property="Width" Value="1280" />
            <Setter Property="Height" Value="800" />
            <Setter Property="MinWidth" Value="1024" />
            <Setter Property="MinHeight" Value="640" />
            <Setter Property="Background" Value="{DynamicResource ZenSurfaceBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ResizeMode" Value="CanResizeWithGrip" />
            <Setter Property="SizeToContent" Value="Manual" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="WindowState" Value="Maximized" />
            <Setter Property="WindowStyle" Value="None" />
        </Style>
    </prism:Dialog.WindowStyle>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="46*" />
            <ColumnDefinition Width="54*" />
        </Grid.ColumnDefinitions>

        <!--  品牌展示区：仅复用参考图的左右分栏结构，视觉由 ZenUI 主题资源组成。  -->
        <Border Background="{DynamicResource ZenPrimaryBrush}">
            <Grid Margin="48,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="42"
                            Height="42"
                            Background="White"
                            CornerRadius="12">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="{DynamicResource ZenPrimaryBrush}"
                                Text="Z" />
                        </Border>
                        <StackPanel Margin="12,1,0,0">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="ZenUI POS" />
                            <TextBlock
                                Margin="0,3,0,0"
                                FontSize="12"
                                Foreground="#CCFFFFFF"
                                Text="简单、专注、高效的收银体验" />
                        </StackPanel>
                    </StackPanel>

                    <zen:ZenButton
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Appearance="Text"
                        Command="{Binding CopySerialCommand}"
                        Content="SN: ZEN-POS-001  ·  复制"
                        Foreground="White"
                        HoverForeground="White"
                        PressedForeground="White"
                        ToolTip="复制演示设备序列号" />
                </Grid>

                <Grid
                    Grid.Row="1"
                    Width="430"
                    Height="430"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Border
                        Margin="34"
                        Background="#20FFFFFF"
                        CornerRadius="48"
                        RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <RotateTransform Angle="-6" />
                        </Border.RenderTransform>
                    </Border>

                    <Border
                        Margin="54"
                        Padding="28"
                        Background="{DynamicResource ZenSurfaceBrush}"
                        CornerRadius="28">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <StackPanel>
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                        Text="今日营业额" />
                                    <TextBlock
                                        Margin="0,5,0,0"
                                        FontSize="28"
                                        FontWeight="SemiBold"
                                        Text="¥ 8,280.00" />
                                </StackPanel>
                                <Border
                                    Width="46"
                                    Height="46"
                                    HorizontalAlignment="Right"
                                    Background="{DynamicResource ZenInfoLightBrush}"
                                    CornerRadius="14">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="21"
                                        Foreground="{DynamicResource ZenPrimaryBrush}"
                                        Text="¥" />
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="1" Margin="0,26,0,22">
                                <Border
                                    Margin="0,0,0,12"
                                    Padding="14"
                                    Background="{DynamicResource ZenSurfaceMutedBrush}"
                                    CornerRadius="10">
                                    <Grid>
                                        <Border
                                            Width="42"
                                            Height="42"
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource ZenInfoLightBrush}"
                                            CornerRadius="10">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource ZenPrimaryBrush}"
                                                Text="咖啡" />
                                        </Border>
                                        <StackPanel Margin="56,2,72,0">
                                            <TextBlock FontWeight="SemiBold" Text="拿铁咖啡" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="12"
                                                Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                                Text="大杯 · 1 件" />
                                        </StackPanel>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="¥ 28" />
                                    </Grid>
                                </Border>

                                <Border
                                    Padding="14"
                                    Background="{DynamicResource ZenSurfaceMutedBrush}"
                                    CornerRadius="10">
                                    <Grid>
                                        <Border
                                            Width="42"
                                            Height="42"
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource ZenSuccessLightBrush}"
                                            CornerRadius="10">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource ZenSuccessActionBrush}"
                                                Text="甜点" />
                                        </Border>
                                        <StackPanel Margin="56,2,72,0">
                                            <TextBlock FontWeight="SemiBold" Text="松露蛋糕" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="12"
                                                Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                                Text="标准 · 1 件" />
                                        </StackPanel>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="¥ 36" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <zen:ZenButton
                                Grid.Row="2"
                                Height="42"
                                Content="模拟结账  ¥ 64.00" />
                        </Grid>
                    </Border>
                </Grid>

                <TextBlock
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="#BFFFFFFF"
                    Text="ZenUI.Wpf · POS 场景演示 · v0.1.0" />
            </Grid>
        </Border>

        <!--  登录区  -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Background="Transparent"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel
                    Margin="0,12,16,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">
                    <zen:ZenButton
                        Width="40"
                        Height="36"
                        Margin="0,0,6,0"
                        Appearance="Text"
                        Click="MinimizeButton_Click"
                        Content="—"
                        FontSize="18"
                        ToolTip="最小化" />
                    <zen:ZenButton
                        Width="40"
                        Height="36"
                        Appearance="Text"
                        Command="{Binding CancelCommand}"
                        Content="×"
                        FontSize="24"
                        ToolTip="关闭" />
                </StackPanel>
            </Grid>

            <ScrollViewer
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <Grid
                    Width="500"
                    Margin="40,42,40,48"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock
                            FontSize="36"
                            FontWeight="SemiBold"
                            Text="欢迎登录" />
                        <TextBlock
                            Margin="0,10,0,0"
                            Foreground="{DynamicResource ZenTextSecondaryBrush}"
                            Text="请选择一种方式进入 ZenUI POS 演示系统" />
                    </StackPanel>

                    <UniformGrid
                        Grid.Row="1"
                        Margin="0,34,0,22"
                        Columns="2">
                        <zen:ZenButton
                            x:Name="AccountTabButton"
                            Height="42"
                            Margin="0,0,6,0"
                            Appearance="{Binding AccountTabAppearance}"
                            Command="{Binding UseAccountLoginCommand}"
                            Content="账号密码登录" />
                        <zen:ZenButton
                            x:Name="CodeTabButton"
                            Height="42"
                            Margin="6,0,0,0"
                            Appearance="{Binding CodeTabAppearance}"
                            Command="{Binding UseCodeLoginCommand}"
                            Content="验证码登录" />
                    </UniformGrid>

                    <Grid Grid.Row="2">
                        <StackPanel Visibility="{Binding AccountPanelVisibility}">
                            <zen:ZenTextBox
                                x:Name="AccountTextBox"
                                Height="50"
                                Text="{Binding Account, UpdateSourceTrigger=PropertyChanged}"
                                Watermark="请输入账号">
                                <zen:ZenTextBox.LeadingContent>
                                    <TextBlock
                                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                        Text="账号" />
                                </zen:ZenTextBox.LeadingContent>
                            </zen:ZenTextBox>

                            <zen:ZenPasswordBox
                                x:Name="PasswordBox"
                                Height="50"
                                Margin="0,14,0,0"
                                IsPasswordRevealEnabled="True"
                                Watermark="输入任意密码">
                                <zen:ZenPasswordBox.LeadingContent>
                                    <TextBlock
                                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                        Text="密码" />
                                </zen:ZenPasswordBox.LeadingContent>
                            </zen:ZenPasswordBox>
                        </StackPanel>

                        <StackPanel Visibility="{Binding CodePanelVisibility}">
                            <zen:ZenTextBox
                                x:Name="PhoneTextBox"
                                Height="50"
                                Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                Watermark="请输入手机号">
                                <zen:ZenTextBox.LeadingContent>
                                    <TextBlock
                                        Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                        Text="手机" />
                                </zen:ZenTextBox.LeadingContent>
                            </zen:ZenTextBox>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="132" />
                                </Grid.ColumnDefinitions>
                                <zen:ZenTextBox
                                    x:Name="CaptchaTextBox"
                                    Height="50"
                                    Text="{Binding CaptchaInput, UpdateSourceTrigger=PropertyChanged}"
                                    Watermark="请输入图形验证码">
                                    <zen:ZenTextBox.LeadingContent>
                                        <TextBlock
                                            Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                            Text="图形码" />
                                    </zen:ZenTextBox.LeadingContent>
                                </zen:ZenTextBox>
                                <zen:ZenButton
                                    Grid.Column="2"
                                    Height="50"
                                    Appearance="Outlined"
                                    Command="{Binding RefreshCaptchaCommand}"
                                    Content="{Binding CaptchaText}"
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    ToolTip="点击更换图形验证码" />
                            </Grid>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="132" />
                                </Grid.ColumnDefinitions>
                                <zen:ZenTextBox
                                    x:Name="CodeTextBox"
                                    Height="50"
                                    Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged}"
                                    Watermark="请输入短信验证码">
                                    <zen:ZenTextBox.LeadingContent>
                                        <TextBlock
                                            Foreground="{DynamicResource ZenTextSecondaryBrush}"
                                            Text="短信码" />
                                    </zen:ZenTextBox.LeadingContent>
                                </zen:ZenTextBox>
                                <zen:ZenButton
                                    x:Name="SendCodeButton"
                                    Grid.Column="2"
                                    Height="50"
                                    Appearance="Outlined"
                                    Command="{Binding SendCodeCommand}"
                                    Content="{Binding SendCodeText}"
                                    IsEnabled="{Binding CanSendCode}" />
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,18,0,22">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource ZenTextSecondaryBrush}"
                            Text="演示模式不会连接服务器或保存凭据" />
                        <zen:ZenButton
                            HorizontalAlignment="Right"
                            Appearance="Text"
                            Command="{Binding ForgotPasswordCommand}"
                            Content="忘记密码？" />
                    </Grid>

                    <StackPanel Grid.Row="4">
                        <zen:ZenAlert
                            Margin="0,0,0,16"
                            Content="{Binding StatusMessage}"
                            Variant="{Binding StatusVariant}"
                            Visibility="{Binding StatusVisibility}" />
                        <zen:ZenButton
                            x:Name="LoginButton"
                            Height="50"
                            Command="{Binding LoginCommand}"
                            Content="登录"
                            FontSize="16"
                            FontWeight="SemiBold"
                            IsDefault="True" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
