<Window
    x:Class="XiaQue.Wpf.Demo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XiaQue.Wpf.Demo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xq="http://www.mnorg.com/2026/"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <StackPanel Height="45" Orientation="Horizontal">
        <xq:XQ_Button Margin="5" Content="Click Me" />
        <xq:XQ_Button
            Margin="5"
            Content="Click Me"
            Type="Success" />
        <xq:XQ_Button
            Margin="5"
            Content="Click Me"
            IsEnabled="False" />
    </StackPanel>
</Window>
