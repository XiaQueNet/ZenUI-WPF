<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">



    <!--  主色  -->
    <Color x:Key="PrimaryEffect">#3c9cff</Color>
    <Color x:Key="PrimaryDarkEffect">#398ade</Color>
    <Color x:Key="PrimaryDisabledEffect">#9acafc</Color>
    <Color x:Key="PrimaryLightEffect">#ecf5ff</Color>
    <SolidColorBrush x:Key="Primary" Color="{StaticResource PrimaryEffect}" />
    <SolidColorBrush x:Key="PrimaryDark" Color="{StaticResource PrimaryDarkEffect}" />
    <SolidColorBrush x:Key="PrimaryDisabled" Color="{StaticResource PrimaryDisabledEffect}" />
    <SolidColorBrush x:Key="PrimaryLight" Color="{StaticResource PrimaryLightEffect}" />


    <!--  成功  -->
    <Color x:Key="SuccessEffect">#19be6b</Color>
    <Color x:Key="SuccessDarkEffect">#18b566</Color>
    <Color x:Key="SuccessDisabledEffect">#71d5a1</Color>
    <Color x:Key="SuccessLightEffect">#dbf1e1</Color>
    <SolidColorBrush x:Key="Success" Color="{StaticResource SuccessEffect}" />
    <SolidColorBrush x:Key="SuccessDark" Color="{StaticResource SuccessDarkEffect}" />
    <SolidColorBrush x:Key="SuccessDisabled" Color="{StaticResource SuccessDisabledEffect}" />
    <SolidColorBrush x:Key="SuccessLight" Color="{StaticResource SuccessLightEffect}" />
</ResourceDictionary>