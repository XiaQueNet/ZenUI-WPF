<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  主色  -->
    <Color x:Key="PrimaryEffect">#095BFF</Color>
    <SolidColorBrush x:Key="Primary" Color="{StaticResource PrimaryEffect}" />

    <!--  成功  -->
    <Color x:Key="SuccessEffect">#19be6b</Color>
    <SolidColorBrush x:Key="Success" Color="{StaticResource SuccessEffect}" />

    <!--  警告  -->
    <Color x:Key="WarningEffect">#faad14</Color>
    <SolidColorBrush x:Key="Warning" Color="{StaticResource WarningEffect}" />

</ResourceDictionary>