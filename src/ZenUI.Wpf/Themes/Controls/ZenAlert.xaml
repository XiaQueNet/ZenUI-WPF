<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:zen="clr-namespace:ZenUI.Wpf.Controls">

    <Style x:Key="ZenAlertStyle" TargetType="{x:Type zen:ZenAlert}">
        <Setter Property="Padding" Value="14,11" />
        <Setter Property="AutomationProperties.LiveSetting" Value="Polite" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type zen:ZenAlert}">
                    <Border x:Name="AlertBorder" Padding="{TemplateBinding Padding}" Background="{DynamicResource ZenInfoLightBrush}" BorderBrush="{DynamicResource ZenInfoBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border x:Name="Icon" Width="18" Height="18" VerticalAlignment="Top" Background="{DynamicResource ZenInfoBrush}" CornerRadius="9">
                                <TextBlock x:Name="IconText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="White" Text="i" />
                            </Border>
                            <ContentPresenter Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Variant" Value="Success">
                            <Setter TargetName="AlertBorder" Property="Background" Value="{DynamicResource ZenSuccessLightBrush}" />
                            <Setter TargetName="AlertBorder" Property="BorderBrush" Value="{DynamicResource ZenSuccessBrush}" />
                            <Setter TargetName="Icon" Property="Background" Value="{DynamicResource ZenSuccessBrush}" />
                            <Setter TargetName="IconText" Property="Text" Value="✓" />
                        </Trigger>
                        <Trigger Property="Variant" Value="Warning">
                            <Setter TargetName="AlertBorder" Property="Background" Value="{DynamicResource ZenWarningLightBrush}" />
                            <Setter TargetName="AlertBorder" Property="BorderBrush" Value="{DynamicResource ZenWarningBrush}" />
                            <Setter TargetName="Icon" Property="Background" Value="{DynamicResource ZenWarningBrush}" />
                            <Setter TargetName="IconText" Property="Text" Value="!" />
                        </Trigger>
                        <Trigger Property="Variant" Value="Error">
                            <Setter TargetName="AlertBorder" Property="Background" Value="{DynamicResource ZenErrorLightBrush}" />
                            <Setter TargetName="AlertBorder" Property="BorderBrush" Value="{DynamicResource ZenErrorBrush}" />
                            <Setter TargetName="Icon" Property="Background" Value="{DynamicResource ZenErrorBrush}" />
                            <Setter TargetName="IconText" Property="Text" Value="×" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style BasedOn="{StaticResource ZenAlertStyle}" TargetType="{x:Type zen:ZenAlert}" />
</ResourceDictionary>
