<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:zen="clr-namespace:ZenUI.Wpf.Controls">

    <!--  WPF shows this adorner only when focus is initiated from the keyboard.  -->
    <Style x:Key="ZenButtonFocusVisualStyle" TargetType="{x:Type Control}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Control}">
                    <Border
                        CornerRadius="13"
                        Style="{StaticResource ZenFocusVisualBorderStyle}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ZenButtonStyle" TargetType="{x:Type zen:ZenButton}">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="5,0" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource ZenButtonFocusVisualStyle}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type zen:ZenButton}">
                    <Border
                        x:Name="BackgroundBorder"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True"
                            TextBlock.FontFamily="{TemplateBinding FontFamily}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Variant" Value="Primary">
                <Setter Property="Background" Value="{DynamicResource ZenPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ZenPrimaryBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="HoverBackground" Value="{DynamicResource ZenPrimaryHoverBrush}" />
                <Setter Property="HoverBorderBrush" Value="{DynamicResource ZenPrimaryHoverBrush}" />
                <Setter Property="HoverForeground" Value="White" />
                <Setter Property="PressedBackground" Value="{DynamicResource ZenPrimaryPressedBrush}" />
                <Setter Property="PressedBorderBrush" Value="{DynamicResource ZenPrimaryPressedBrush}" />
                <Setter Property="PressedForeground" Value="White" />
            </Trigger>
            <Trigger Property="Variant" Value="Success">
                <Setter Property="Background" Value="{DynamicResource ZenSuccessActionBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ZenSuccessActionBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="HoverBackground" Value="{DynamicResource ZenSuccessActionHoverBrush}" />
                <Setter Property="HoverBorderBrush" Value="{DynamicResource ZenSuccessActionHoverBrush}" />
                <Setter Property="HoverForeground" Value="White" />
                <Setter Property="PressedBackground" Value="{DynamicResource ZenSuccessActionPressedBrush}" />
                <Setter Property="PressedBorderBrush" Value="{DynamicResource ZenSuccessActionPressedBrush}" />
                <Setter Property="PressedForeground" Value="White" />
            </Trigger>
            <Trigger Property="Variant" Value="Warning">
                <Setter Property="Background" Value="{DynamicResource ZenWarningBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ZenWarningBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ZenWarningForegroundBrush}" />
                <Setter Property="HoverBackground" Value="{DynamicResource ZenWarningHoverBrush}" />
                <Setter Property="HoverBorderBrush" Value="{DynamicResource ZenWarningHoverBrush}" />
                <Setter Property="HoverForeground" Value="{DynamicResource ZenWarningForegroundBrush}" />
                <Setter Property="PressedBackground" Value="{DynamicResource ZenWarningPressedBrush}" />
                <Setter Property="PressedBorderBrush" Value="{DynamicResource ZenWarningPressedBrush}" />
                <Setter Property="PressedForeground" Value="{DynamicResource ZenWarningForegroundBrush}" />
            </Trigger>
            <Trigger Property="Appearance" Value="Outlined">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="{DynamicResource ZenPrimaryBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{DynamicResource ZenPrimaryBrush}" />
                <Setter Property="HoverBackground" Value="{DynamicResource ZenInfoLightBrush}" />
                <Setter Property="HoverBorderBrush" Value="{DynamicResource ZenPrimaryHoverBrush}" />
                <Setter Property="HoverForeground" Value="{DynamicResource ZenPrimaryHoverBrush}" />
                <Setter Property="PressedBackground" Value="{DynamicResource ZenInfoLightBrush}" />
                <Setter Property="PressedBorderBrush" Value="{DynamicResource ZenPrimaryPressedBrush}" />
                <Setter Property="PressedForeground" Value="{DynamicResource ZenPrimaryPressedBrush}" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="Appearance" Value="Outlined" />
                    <Condition Property="Variant" Value="Success" />
                </MultiTrigger.Conditions>
                <Setter Property="BorderBrush" Value="{DynamicResource ZenSuccessActionBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ZenSuccessActionBrush}" />
                <Setter Property="HoverBackground" Value="{DynamicResource ZenSuccessLightBrush}" />
                <Setter Property="HoverBorderBrush" Value="{DynamicResource ZenSuccessActionHoverBrush}" />
                <Setter Property="HoverForeground" Value="{DynamicResource ZenSuccessActionHoverBrush}" />
                <Setter Property="PressedBackground" Value="{DynamicResource ZenSuccessLightBrush}" />
                <Setter Property="PressedBorderBrush" Value="{DynamicResource ZenSuccessActionPressedBrush}" />
                <Setter Property="PressedForeground" Value="{DynamicResource ZenSuccessActionPressedBrush}" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="Appearance" Value="Outlined" />
                    <Condition Property="Variant" Value="Warning" />
                </MultiTrigger.Conditions>
                <Setter Property="BorderBrush" Value="{DynamicResource ZenWarningBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ZenWarningBrush}" />
                <Setter Property="HoverBackground" Value="{DynamicResource ZenWarningLightBrush}" />
                <Setter Property="HoverBorderBrush" Value="{DynamicResource ZenWarningHoverBrush}" />
                <Setter Property="HoverForeground" Value="{DynamicResource ZenWarningHoverBrush}" />
                <Setter Property="PressedBackground" Value="{DynamicResource ZenWarningLightBrush}" />
                <Setter Property="PressedBorderBrush" Value="{DynamicResource ZenWarningPressedBrush}" />
                <Setter Property="PressedForeground" Value="{DynamicResource ZenWarningPressedBrush}" />
            </MultiTrigger>
            <Trigger Property="Appearance" Value="Text">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{DynamicResource ZenPrimaryBrush}" />
                <Setter Property="HoverBackground" Value="Transparent" />
                <Setter Property="HoverBorderBrush" Value="Transparent" />
                <Setter Property="HoverForeground" Value="{DynamicResource ZenPrimaryHoverBrush}" />
                <Setter Property="PressedBackground" Value="Transparent" />
                <Setter Property="PressedBorderBrush" Value="Transparent" />
                <Setter Property="PressedForeground" Value="{DynamicResource ZenPrimaryPressedBrush}" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="Appearance" Value="Text" />
                    <Condition Property="Variant" Value="Success" />
                </MultiTrigger.Conditions>
                <Setter Property="Foreground" Value="{DynamicResource ZenSuccessActionBrush}" />
                <Setter Property="HoverForeground" Value="{DynamicResource ZenSuccessActionHoverBrush}" />
                <Setter Property="PressedForeground" Value="{DynamicResource ZenSuccessActionPressedBrush}" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="Appearance" Value="Text" />
                    <Condition Property="Variant" Value="Warning" />
                </MultiTrigger.Conditions>
                <Setter Property="Foreground" Value="{DynamicResource ZenWarningBrush}" />
                <Setter Property="HoverForeground" Value="{DynamicResource ZenWarningHoverBrush}" />
                <Setter Property="PressedForeground" Value="{DynamicResource ZenWarningPressedBrush}" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsPressed" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{Binding HoverBackground, RelativeSource={RelativeSource Self}}" />
                <Setter Property="BorderBrush" Value="{Binding HoverBorderBrush, RelativeSource={RelativeSource Self}}" />
                <Setter Property="Foreground" Value="{Binding HoverForeground, RelativeSource={RelativeSource Self}}" />
            </MultiTrigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{Binding PressedBackground, RelativeSource={RelativeSource Self}}" />
                <Setter Property="BorderBrush" Value="{Binding PressedBorderBrush, RelativeSource={RelativeSource Self}}" />
                <Setter Property="Foreground" Value="{Binding PressedForeground, RelativeSource={RelativeSource Self}}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4" />
                <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style BasedOn="{StaticResource ZenButtonStyle}" TargetType="{x:Type zen:ZenButton}" />

</ResourceDictionary>
