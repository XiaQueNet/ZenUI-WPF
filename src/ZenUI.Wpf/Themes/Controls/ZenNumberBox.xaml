<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:zen="clr-namespace:ZenUI.Wpf.Controls">

    <CornerRadius x:Key="ZenNumberBoxLeftButtonCornerRadius">5,0,0,5</CornerRadius>
    <CornerRadius x:Key="ZenNumberBoxRightButtonCornerRadius">0,5,5,0</CornerRadius>
    <CornerRadius x:Key="ZenNumberBoxTopRightButtonCornerRadius">0,5,0,0</CornerRadius>
    <CornerRadius x:Key="ZenNumberBoxBottomRightButtonCornerRadius">0,0,5,0</CornerRadius>

    <Style x:Key="ZenNumberBoxRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="Width" Value="34" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="{DynamicResource ZenTextSecondaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border
                        x:Name="ButtonBackground"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBackground" Property="Background" Value="{DynamicResource ZenSurfaceHoverBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ZenTextPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBackground" Property="Background" Value="{DynamicResource ZenSurfaceMutedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter Property="Opacity" Value="0.35" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ZenNumberBoxTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Padding" Value="{DynamicResource ZenInputControlPadding}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ZenTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource ZenTextPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style x:Key="ZenNumberBoxStyle" TargetType="{x:Type zen:ZenNumberBox}">
        <Setter Property="MinWidth" Value="112" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Background" Value="{DynamicResource ZenSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ZenBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type zen:ZenNumberBox}">
                    <Border
                        x:Name="InputBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource ZenInputControlCornerRadius}">
                        <Grid>
                            <Grid x:Name="HorizontalLayout">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="34" />
                                </Grid.ColumnDefinitions>
                                <RepeatButton
                                    x:Name="PART_DecreaseButton"
                                    AutomationProperties.Name="减少"
                                    Style="{StaticResource ZenNumberBoxRepeatButtonStyle}"
                                    Tag="{StaticResource ZenNumberBoxLeftButtonCornerRadius}">
                                    <Grid Width="14" Height="14">
                                        <Path
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Data="M 0,0 L 10,0"
                                            Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type RepeatButton}}}"
                                            StrokeEndLineCap="Round"
                                            StrokeStartLineCap="Round"
                                            StrokeThickness="1.5"
                                            Stretch="None">
                                            <Path.RenderTransform>
                                                <TranslateTransform Y="1" />
                                            </Path.RenderTransform>
                                        </Path>
                                    </Grid>
                                </RepeatButton>
                                <Border Grid.Column="1" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,0">
                                    <TextBox
                                        x:Name="PART_TextBox"
                                        IsReadOnly="{TemplateBinding IsReadOnly}"
                                        Style="{StaticResource ZenNumberBoxTextBoxStyle}" />
                                </Border>
                                <RepeatButton
                                    x:Name="PART_IncreaseButton"
                                    Grid.Column="2"
                                    AutomationProperties.Name="增加"
                                    Style="{StaticResource ZenNumberBoxRepeatButtonStyle}"
                                    Tag="{StaticResource ZenNumberBoxRightButtonCornerRadius}">
                                    <Grid Width="14" Height="14">
                                        <Path
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Data="M 0,5 L 10,5 M 5,0 L 5,10"
                                            Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type RepeatButton}}}"
                                            StrokeEndLineCap="Round"
                                            StrokeStartLineCap="Round"
                                            StrokeThickness="1.5"
                                            Stretch="None" />
                                    </Grid>
                                </RepeatButton>
                            </Grid>

                            <Grid x:Name="VerticalLayout" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="PART_VerticalTextBox"
                                    IsReadOnly="{TemplateBinding IsReadOnly}"
                                    Style="{StaticResource ZenNumberBoxTextBoxStyle}" />
                                <Border Grid.Column="1" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <RepeatButton
                                            x:Name="PART_VerticalIncreaseButton"
                                            Width="Auto"
                                            AutomationProperties.Name="增加"
                                            Style="{StaticResource ZenNumberBoxRepeatButtonStyle}"
                                            Tag="{StaticResource ZenNumberBoxTopRightButtonCornerRadius}">
                                            <Viewbox Width="12" Height="7">
                                                <Path
                                                    Data="M 1,6 L 6,1 L 11,6"
                                                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type RepeatButton}}}"
                                                    StrokeEndLineCap="Round"
                                                    StrokeLineJoin="Round"
                                                    StrokeStartLineCap="Round"
                                                    StrokeThickness="1.4" />
                                            </Viewbox>
                                        </RepeatButton>
                                        <RepeatButton
                                            x:Name="PART_VerticalDecreaseButton"
                                            Grid.Row="1"
                                            Width="Auto"
                                            AutomationProperties.Name="减少"
                                            Style="{StaticResource ZenNumberBoxRepeatButtonStyle}"
                                            Tag="{StaticResource ZenNumberBoxBottomRightButtonCornerRadius}">
                                            <Viewbox Width="12" Height="7">
                                                <Path
                                                    Data="M 1,1 L 6,6 L 11,1"
                                                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type RepeatButton}}}"
                                                    StrokeEndLineCap="Round"
                                                    StrokeLineJoin="Round"
                                                    StrokeStartLineCap="Round"
                                                    StrokeThickness="1.4" />
                                            </Viewbox>
                                        </RepeatButton>
                                        <Border
                                            x:Name="VerticalButtonDivider"
                                            Grid.RowSpan="2"
                                            Height="1"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource ZenDividerBrush}"
                                            IsHitTestVisible="False"
                                            Panel.ZIndex="1" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ButtonMode" Value="Vertical">
                            <Setter TargetName="HorizontalLayout" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="VerticalLayout" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource ZenBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource ZenPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="InputBorder" Property="Background" Value="{DynamicResource ZenSurfaceDisabledBrush}" />
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource ZenNumberBoxStyle}" TargetType="{x:Type zen:ZenNumberBox}" />

</ResourceDictionary>
